---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Chevron from '../components/Chevron.astro';
import Icon from '../components/Icon.astro';

const loop = [
  {
    idx: '01',
    verb: 'Inspect',
    lede: 'It learns your ground.',
    body: 'A forward-deployed agent reads your codebase, docs, tickets, and telemetry through access you grant — building a real map of how the business actually runs, not a generic guess.',
  },
  {
    idx: '02',
    verb: 'Propose',
    lede: 'It briefs you first.',
    body: 'Before touching anything, the agent returns proposals: what to build, what it will cost, what could break. You read the brief and decide. Nothing ships without your word.',
  },
  {
    idx: '03',
    verb: 'Implement',
    lede: 'It executes on command.',
    body: 'Approve a proposal and the agent does the work — opening reviewable changes inside your workflow, with every action logged. Advance your own ideas the same way.',
  },
];

const control = [
  {
    code: 'C-01',
    t: 'Scoped access',
    d: 'Every capability is granted explicitly and bounded — the same badge-and-scope you would give a trusted contractor. No standing keys to everything.',
  },
  {
    code: 'C-02',
    t: 'Full audit trail',
    d: 'Every file read, proposal, and change is recorded and attributable. You can always answer “what did it touch, and why?”',
  },
  {
    code: 'C-03',
    t: 'Approval gates',
    d: 'Inspection is autonomous; action is not. Consequential steps wait behind a human sign-off you control.',
  },
  {
    code: 'C-04',
    t: 'One-click revoke',
    d: 'Pull an agent off the ground instantly. Access ends the moment you decide it does — no cleanup, no residue.',
  },
];

const record = [
  {
    idx: 'R-01',
    label: 'Research',
    t: 'Published science, not press releases.',
    d: 'Peer-reviewed work at top-tier venues — NeurIPS among them — and in leading journals. We deploy algorithms we understand to the metal, because we helped write the literature on them.',
  },
  {
    idx: 'R-02',
    label: 'Engineering',
    t: 'Systems that hold at scale.',
    d: 'Careers spent shipping AI-enabled applications, distributed systems, and highly scalable software in production — the unglamorous rigor that keeps things standing under real load.',
  },
  {
    idx: 'R-03',
    label: 'Platforms',
    t: 'Custom-built for the ground.',
    d: 'We build bespoke platforms around a domain instead of bending the domain to fit someone else’s tool. The agents run on infrastructure we designed for exactly this.',
  },
  {
    idx: 'R-04',
    label: 'Method',
    t: 'State of the art, in production.',
    d: 'We track the research edge and put it to work where it earns its place — measured against your outcomes, not a demo reel.',
  },
];

// Ordered alphabetically by surname. Add each LinkedIn URL to show the link.
const founders = [
  {
    name: 'Łukasz Augustyniak',
    bio: 'NLP researcher focused on large language models and AI for legal work. Published across sentiment analysis, aspect extraction, and speech-recognition evaluation.',
    scholar: 'https://scholar.google.com/citations?user=o3apDSYAAAAJ&hl=en',
    linkedin: 'https://www.linkedin.com/in/lukaszaugustyniak/',
  },
  {
    name: 'Roman Bartusiak',
    bio: 'ML engineer and researcher in network science and distributed graph processing. Co-author of the LEPISZCZE Polish NLP benchmark and WordNet2Vec.',
    scholar: 'https://scholar.google.com/citations?user=mk68epwAAAAJ&hl=en',
    linkedin: 'https://www.linkedin.com/in/romanbartusiak/',
  },
  {
    name: 'Adrian Szymczak',
    bio: 'AI solutions architect spanning large language models, data science, and software engineering. Published work on conversational-speech modeling and ASR-error robustness.',
    scholar: 'https://scholar.google.com/citations?user=fNqZL_4AAAAJ&hl=en',
    linkedin: 'https://www.linkedin.com/in/adrianszymczak/',
  },
];

const vectors = [
  {
    tag: 'Vector A · Humans',
    t: 'Forward-deployed engineers',
    d: 'Our people embed with your team, learn the domain, and ship inside your reality — the proven model for making a hard technology actually land.',
  },
  {
    tag: 'Vector B · Agents',
    t: 'Forward-deployed agents',
    d: 'The platform we are building: supervised AI agents that deploy the same way — granted access, held to command, running inspect → propose → implement at machine pace.',
  },
];
---
<Base>
  <Header />

  <main id="main">
    <!-- ============================= HERO ============================= -->
    <section
      aria-label="Introduction"
      class="relative overflow-hidden bg-ink text-chalk"
    >
      <div class="grid-ticks pointer-events-none absolute inset-0 opacity-60" aria-hidden="true"></div>

      <div class="brief-shell relative pt-16 pb-20 sm:pt-24 sm:pb-28">
        <div class="flex items-center gap-4 rise" style="animation-delay:.02s">
          <span class="mono-label text-field-soft">01 / Deployment brief</span>
          <span class="h-px flex-1 bg-[var(--edge-on-ink)]"></span>
          <span class="mono-label inline-flex items-center gap-2 text-signal">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-signal"></span>
            Accepting new deployments
          </span>
        </div>

        <h1 class="mt-10 max-w-[16ch] text-hero font-extrabold text-chalk rise" style="animation-delay:.08s">
          Forward-deployed agents.
          <span class="text-signal">Under your command.</span>
        </h1>

        <p class="mt-8 max-w-2xl text-lead font-semibold text-chalk rise" style="animation-delay:.13s">
          AI that works inside your business like a trusted hire — and only
          where you allow it.
        </p>

        <p class="mt-5 max-w-2xl text-base leading-relaxed text-field-soft rise" style="animation-delay:.18s">
          The way companies actually adopt hard technology is to
          <span class="text-chalk">embed</span> — put a trusted expert on the
          ground who learns the domain and ships inside it. forward.army deploys
          AI agents the same way: granted controlled access, held to command,
          set loose to inspect your business, propose the work, and — when you
          approve — implement it.
        </p>

        <div class="mt-11 flex flex-wrap items-center gap-4 rise" style="animation-delay:.24s">
          <a
            href="#request-form"
            class="group inline-flex items-center gap-3 bg-signal px-6 py-3.5 font-display text-lg font-bold text-ink transition-colors hover:bg-chalk hover:text-ink"
          >
            Request access
            <Chevron count={2} strokeWidth={6} class="chev-advance h-4 w-auto" />
          </a>
          <a
            href="#doctrine"
            class="group inline-flex items-center gap-3 border border-[var(--edge-on-ink)] px-6 py-3.5 font-display text-lg font-bold text-chalk transition-colors hover:border-chalk"
          >
            Read the doctrine
          </a>
        </div>

        <!-- tactical spec strip -->
        <dl class="mt-16 grid max-w-3xl grid-cols-2 gap-x-8 gap-y-6 border-t border-[var(--edge-on-ink)] pt-8 sm:grid-cols-3 rise" style="animation-delay:.32s">
          {[
            ['Access model', 'Granted · scoped · revocable'],
            ['Autonomy', 'Supervised, gated on approval'],
            ['Built for', 'Any business, any team'],
          ].map(([k, v]) => (
            <div>
              <dt class="mono-label text-field-soft">{k}</dt>
              <dd class="mt-2 font-display text-lg font-bold text-chalk">{v}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <!-- ============================ DOCTRINE ========================== -->
    <section id="doctrine" aria-labelledby="doctrine-h" class="bg-bone">
      <div class="brief-shell grid gap-x-16 gap-y-10 py-24 md:grid-cols-[1.1fr_1fr]">
        <div>
          <span class="mono-label text-signal-deep">02 / Doctrine</span>
          <h2 id="doctrine-h" class="mt-6 text-h2 text-ink">
            Trust is earned<br />on the ground.
          </h2>
        </div>
        <div class="max-w-xl space-y-6 text-lead text-field md:pt-14">
          <p>
            A demo never changed a company. Embedding did. Sit a capable
            expert next to the problem, give them real access, and let them
            learn the terrain — that is how technology crosses from
            <span class="text-ink">interesting</span> to
            <span class="text-ink">operational</span>.
          </p>
          <p>
            We run that model both ways. Our engineers deploy forward into your
            team. And we are building the platform that lets
            <span class="text-ink">agents</span> deploy forward too — with the
            same discipline of access, and the same answer to the only question
            that matters: <span class="text-ink">who is in command?</span>
          </p>
        </div>
      </div>
    </section>

    <!-- ============================== LOOP ============================ -->
    <section id="loop" aria-labelledby="loop-h" class="border-t border-[var(--edge)] bg-bone-sink">
      <div class="brief-shell py-24">
        <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <span class="mono-label text-signal-deep">03 / The loop</span>
            <h2 id="loop-h" class="mt-6 text-h2 text-ink">Inspect. Propose. Implement.</h2>
          </div>
          <p class="max-w-sm text-field">
            The loop a good hire runs in their first month — now available as
            supervised autonomy.
          </p>
        </div>

        <!-- Numbered sequence, divided by rules (not identical cards) -->
        <ol class="mt-16 grid gap-y-12 md:grid-cols-3 md:gap-y-0">
          {loop.map((step, i) => (
            <li class={`relative ${i > 0 ? 'md:border-l md:border-[var(--edge-strong)] md:pl-10' : 'md:pr-10'} ${i === 1 ? 'md:px-10' : ''}`}>
              <div class="flex items-center gap-4">
                <span class="font-mono text-4xl font-medium leading-none text-signal-deep">
                  {step.idx}
                </span>
                {i < 2 && (
                  <Chevron count={2} strokeWidth={5} class="hidden h-3 w-auto text-signal-deep md:block" />
                )}
              </div>
              <h3 class="mt-6 text-h3 text-ink">{step.verb}</h3>
              <p class="mt-1 font-display text-lg font-bold text-signal-deep">{step.lede}</p>
              <p class="mt-4 max-w-sm text-field">{step.body}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- ============================ COMMAND =========================== -->
    <section id="command" aria-labelledby="command-h" class="relative overflow-hidden bg-ink text-chalk">
      <div class="grid-ticks pointer-events-none absolute inset-0 opacity-50" aria-hidden="true"></div>
      <div class="brief-shell relative grid gap-x-16 gap-y-12 py-24 md:grid-cols-[0.85fr_1.15fr]">
        <div class="md:sticky md:top-24 md:self-start">
          <span class="mono-label text-signal">04 / Command &amp; control</span>
          <h2 id="command-h" class="mt-6 text-h2 text-chalk">
            Autonomy you<br />can pull back.
          </h2>
          <p class="mt-6 max-w-md text-lead text-field-soft">
            The differentiator isn't that the agents are capable. It's that
            you stay in command of everything they can reach and everything
            they do.
          </p>
        </div>

        <!-- Control-code dossier (matches the service-record rhythm, not cards) -->
        <ol class="border-t border-[var(--edge-on-ink)]">
          {control.map((c) => (
            <li class="grid items-baseline gap-x-6 gap-y-2 border-b border-[var(--edge-on-ink)] py-7 md:grid-cols-[4rem_1fr_1.3fr]">
              <span class="font-mono text-sm font-medium text-signal">{c.code}</span>
              <h3 class="flex items-center gap-3 font-display text-xl font-bold text-chalk">
                <Chevron count={1} strokeWidth={6} class="h-3.5 w-auto shrink-0 text-signal" />
                {c.t}
              </h3>
              <p class="text-field-soft">{c.d}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- ============================ PEOPLE =========================== -->
    <section id="team" aria-labelledby="team-h" class="border-t border-[var(--edge)] bg-bone-sink">
      <div class="brief-shell py-24">
        <div class="grid gap-x-16 gap-y-8 md:grid-cols-[1.1fr_1fr] md:items-end">
          <div>
            <span class="mono-label text-signal-deep">05 / Service record</span>
            <h2 id="team-h" class="mt-6 text-h2 text-ink">
              Not just agents.<br />The people who deploy them.
            </h2>
          </div>
          <p class="max-w-xl text-lead text-field">
            Every forward-deployed agent is designed, governed, and backed by a
            team that has spent careers at the frontier of AI research and
            large-scale software.
          </p>
        </div>

        <dl class="mt-16 border-t border-[var(--edge-strong)]">
          {record.map((r) => (
            <div class="grid items-baseline gap-x-8 gap-y-2 border-b border-[var(--edge)] py-7 md:grid-cols-[8rem_1fr_1.1fr]">
              <dt class="contents">
                <span class="flex items-center gap-3">
                  <span class="font-mono text-sm font-medium text-signal-deep">{r.idx}</span>
                  <span class="mono-label text-field">{r.label}</span>
                </span>
                <span class="font-display text-h3 font-bold text-ink">{r.t}</span>
              </dt>
              <dd class="text-field">{r.d}</dd>
            </div>
          ))}
        </dl>

        <!-- Founders — named, verifiable proof -->
        <div class="mt-16">
          <span class="mono-label text-field">Signed by — founders</span>
          <ul class="mt-6 grid gap-px overflow-hidden border border-[var(--edge)] bg-[var(--edge)] sm:grid-cols-3">
            {founders.map((f) => (
              <li class="flex flex-col gap-4 bg-bone-sink p-7">
                <h3 class="text-h3 font-bold text-ink">{f.name}</h3>
                <p class="text-sm leading-relaxed text-field">{f.bio}</p>
                <div class="mt-auto flex items-center gap-3 pt-2">
                  <a
                    href={f.scholar}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex h-10 w-10 items-center justify-center border border-[var(--edge-strong)] text-field transition-colors hover:border-signal-deep hover:text-signal-deep"
                    aria-label={`${f.name} — Google Scholar publications (opens in a new tab)`}
                  >
                    <Icon name="scholar" class="h-5 w-5" />
                  </a>
                  {f.linkedin && (
                    <a
                      href={f.linkedin}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex h-10 w-10 items-center justify-center border border-[var(--edge-strong)] text-field transition-colors hover:border-signal-deep hover:text-signal-deep"
                      aria-label={`${f.name} — LinkedIn profile (opens in a new tab)`}
                    >
                      <Icon name="linkedin" class="h-[1.15rem] w-[1.15rem]" />
                    </a>
                  )}
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- ============================ VECTORS ========================== -->
    <section aria-labelledby="vectors-h" class="bg-bone">
      <div class="brief-shell py-24">
        <span class="mono-label text-signal-deep">06 / Two vectors</span>
        <h2 id="vectors-h" class="mt-6 max-w-2xl text-h2 text-ink">
          Same doctrine. Human and machine.
        </h2>

        <div class="mt-14 grid gap-8 md:grid-cols-2">
          {vectors.map((v, i) => (
            <article
              class={`flex flex-col justify-between p-9 ${
                i === 1 ? 'bg-ink text-chalk' : 'border border-[var(--edge-strong)] text-ink'
              }`}
            >
              <div>
                <span class={`mono-label ${i === 1 ? 'text-signal' : 'text-signal-deep'}`}>{v.tag}</span>
                <h3 class={`mt-5 text-h3 ${i === 1 ? 'text-chalk' : 'text-ink'}`}>{v.t}</h3>
                <p class={`mt-4 text-lead ${i === 1 ? 'text-field-soft' : 'text-field'}`}>{v.d}</p>
              </div>
              <Chevron
                count={3}
                strokeWidth={4}
                class={`mt-10 h-4 w-auto ${i === 1 ? 'text-signal' : 'text-field-soft'}`}
              />
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================= DEPLOY =========================== -->
    <section id="deploy" aria-labelledby="deploy-h" class="border-t border-[var(--edge)] bg-signal text-ink">
      <div class="brief-shell grid gap-x-16 gap-y-12 py-24 md:grid-cols-[1fr_1fr] md:items-start">
        <div class="md:pt-4">
          <span class="mono-label text-ink">07 / Request access</span>
          <h2 id="deploy-h" class="mt-6 text-h2 text-ink">
            Give one agent a<br />bounded piece of ground.
          </h2>
          <p class="mt-6 max-w-xl text-lead text-ink">
            Start with one bounded deployment. Bring a real problem and a scope
            you're comfortable granting — we'll deploy, brief you, and you decide
            what ships.
          </p>

          <ul class="mt-10 space-y-3">
            {[
              'No access is granted until you say so.',
              'Everything the agent does is logged and reversible.',
              'Reply within one business day.',
            ].map((point) => (
              <li class="flex items-start gap-3 text-ink">
                <Chevron count={1} strokeWidth={7} class="mt-1.5 h-3 w-auto shrink-0" />
                <span class="font-medium">{point}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Request-access form on an ink card (focal, high contrast) -->
        <div id="request-form" class="scroll-mt-24 bg-ink p-7 text-chalk sm:p-9">
          <form id="access-form" class="space-y-5" novalidate>
            <p class="mono-label text-field-soft">Request access</p>

            <div class="grid gap-5 sm:grid-cols-2">
              <div class="flex flex-col gap-2">
                <label for="f-name" class="mono-label text-field-soft">Name</label>
                <input id="f-name" name="name" type="text" autocomplete="name" required
                  class="rounded-none border border-[var(--edge-on-ink)] bg-ink-raise px-4 py-3 text-chalk placeholder:text-field-soft focus:border-signal"
                  placeholder="Jane Rivera" />
              </div>
              <div class="flex flex-col gap-2">
                <label for="f-company" class="mono-label text-field-soft">Company</label>
                <input id="f-company" name="company" type="text" autocomplete="organization" required
                  class="rounded-none border border-[var(--edge-on-ink)] bg-ink-raise px-4 py-3 text-chalk placeholder:text-field-soft focus:border-signal"
                  placeholder="Acme Corp" />
              </div>
            </div>

            <div class="flex flex-col gap-2">
              <label for="f-email" class="mono-label text-field-soft">Work email</label>
              <input id="f-email" name="email" type="email" autocomplete="email" required
                class="rounded-none border border-[var(--edge-on-ink)] bg-ink-raise px-4 py-3 text-chalk placeholder:text-field-soft focus:border-signal"
                placeholder="jane@acme.com" />
            </div>

            <div class="flex flex-col gap-2">
              <label for="f-usecase" class="mono-label text-field-soft">What would you deploy an agent on?</label>
              <textarea id="f-usecase" name="usecase" rows="3" required
                class="resize-y rounded-none border border-[var(--edge-on-ink)] bg-ink-raise px-4 py-3 text-chalk placeholder:text-field-soft focus:border-signal"
                placeholder="One workflow, system, or question you'd start with."></textarea>
            </div>

            <!-- Honeypot: hidden from humans, catches bots -->
            <div class="hidden" aria-hidden="true">
              <label>Leave this empty<input name="website" type="text" tabindex="-1" autocomplete="off" /></label>
            </div>

            <button type="submit"
              class="group inline-flex w-full items-center justify-center gap-3 bg-signal px-6 py-4 font-display text-lg font-bold text-ink transition-colors hover:bg-chalk hover:text-ink sm:w-auto">
              <span data-label>Request access</span>
              <Chevron count={2} strokeWidth={6} class="chev-advance h-4 w-auto" />
            </button>
          </form>

          <!-- Live region: status, success, error -->
          <p id="form-status" class="mt-4 text-sm text-field-soft" role="status" aria-live="polite"></p>

          <div id="form-success" hidden class="border-l-2 border-signal pl-5">
            <p class="font-display text-xl font-bold text-chalk">Request received.</p>
            <p class="mt-2 text-field-soft">
              We'll reply within one business day with next steps. Nothing is
              accessed until you grant it.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<script>
  const form = document.getElementById('access-form') as HTMLFormElement | null;
  const statusEl = document.getElementById('form-status');
  const successEl = document.getElementById('form-success');
  const ENDPOINT = '/api/request-access';
  const FALLBACK = 'command@forward.army';

  if (form && statusEl && successEl) {
    const btn = form.querySelector('button[type=submit]') as HTMLButtonElement;
    const btnLabel = form.querySelector('[data-label]');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      statusEl.textContent = '';
      statusEl.className = 'mt-4 text-sm text-field-soft';

      // Honeypot + native validity
      if ((form.elements.namedItem('website') as HTMLInputElement)?.value) return;
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      const data = Object.fromEntries(new FormData(form).entries());
      btn.disabled = true;
      if (btnLabel) btnLabel.textContent = 'Sending…';

      try {
        const res = await fetch(ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (!res.ok) throw new Error(String(res.status));
        form.hidden = true;
        successEl.hidden = false;
        (successEl.querySelector('p') as HTMLElement)?.focus?.();
      } catch (err) {
        btn.disabled = false;
        if (btnLabel) btnLabel.textContent = 'Request access';
        statusEl.className = 'mt-4 text-sm text-chalk';
        statusEl.innerHTML =
          'Could not send just now. Email us directly at ' +
          '<a class="font-semibold text-signal underline" href="mailto:' +
          FALLBACK +
          '">' +
          FALLBACK +
          '</a>.';
      }
    });
  }
</script>
