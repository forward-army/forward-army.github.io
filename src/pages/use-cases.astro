---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Chevron from '../components/Chevron.astro';
import { usecaseGroups } from '../data/usecases.js';

const title = 'Use cases — custom agents for an AI-first company';
const description =
  'forward.army builds bespoke agents trained on your context and wired into Slack, your tickets, and your repos — from codebase housekeeping to incident response. Governed, and shipping real work.';
---
<Base title={title} description={description}>
  <Header />

  <main id="main">
    <!-- ============================= HERO ============================= -->
    <section class="relative overflow-hidden bg-ink text-chalk">
      <div class="grid-ticks pointer-events-none absolute inset-0 opacity-60" aria-hidden="true"></div>
      <div class="brief-shell relative pt-14 pb-20 sm:pt-20 sm:pb-24">
        <a href="/" class="group inline-flex items-center gap-2 mono-label text-field-soft transition-colors hover:text-signal">
          <Chevron count={1} strokeWidth={6} class="h-[0.7rem] w-auto rotate-180" />
          Back to forward.army
        </a>

        <span class="mono-label mt-10 block text-signal">Use cases</span>
        <h1 class="mt-5 max-w-[20ch] text-hero font-extrabold leading-[0.98] text-chalk">
          Put an agent on the<br />
          <span class="text-signal">work nobody has time for.</span>
        </h1>
        <p class="mt-8 max-w-2xl text-lead font-semibold text-chalk">
          Every forward agent is built for your context — not a generic bot.
        </p>
        <p class="mt-5 max-w-2xl text-base leading-relaxed text-field-soft">
          We develop each agent for a specific job — automating as much as
          possible in deterministic code so it is reliable and testable, and
          using the model only where it earns its place. Then we wire it into
          Slack, your tickets, and your systems, and hold it to the same command
          you would give a trusted hire. Here is where teams start toward an
          AI-first company.
        </p>
      </div>
    </section>

    <!-- ============================ CATALOG ========================== -->
    <section aria-label="Use cases" class="bg-bone">
      <div class="brief-shell py-16 sm:py-20">
        {usecaseGroups.map((g, gi) => (
          <div class={gi > 0 ? 'mt-20' : ''}>
            <h2 class="reveal mono-label text-signal-deep">{g.group}</h2>
            <ol>
              {g.items.map((u, i) => {
                const n = usecaseGroups.slice(0, gi).reduce((s, x) => s + x.items.length, 0) + i + 1;
                return (
                  <li class="reveal grid gap-x-12 gap-y-5 border-b border-[var(--edge-strong)] py-11 first:border-t first:mt-6 md:grid-cols-[0.9fr_1.1fr] md:items-start">
                    <div>
                      <div class="flex items-baseline gap-3">
                        <span class="font-mono text-sm font-medium text-signal-deep">{String(n).padStart(2, '0')}</span>
                        <h3 class="font-display text-h3 font-bold text-ink">{u.t}</h3>
                      </div>
                      <ul class="mt-5 flex flex-wrap gap-2" aria-label="Connects to">
                        {u.connects.map((tag) => (
                          <li class="mono-label border border-[var(--edge-strong)] px-2.5 py-1 text-field">{tag}</li>
                        ))}
                      </ul>
                    </div>
                    <div>
                      <p class="font-display text-lg font-bold text-signal-deep">{u.lede}</p>
                      <p class="mt-3 text-field">{u.body}</p>
                    </div>
                  </li>
                );
              })}
            </ol>
          </div>
        ))}

        <p class="reveal mt-14 max-w-2xl text-lead text-field">
          Don't see yours? That's the point — every forward agent is developed
          for your context. <span class="text-ink">Bring the job.</span>
        </p>
      </div>
    </section>

    <!-- ============================== CTA ============================= -->
    <section class="border-t border-[var(--edge)] bg-signal text-ink">
      <div class="brief-shell grid gap-x-16 gap-y-8 py-20 md:grid-cols-[1.3fr_1fr] md:items-center">
        <div>
          <h2 class="text-h2 text-ink">Pick a job. We'll deploy the agent.</h2>
          <p class="mt-5 max-w-xl text-lead text-ink">
            Bring a real problem and a scope you are comfortable granting. We
            deploy, brief you, and you decide what ships.
          </p>
        </div>
        <div class="md:justify-self-end">
          <a
            href="/#request-form"
            class="group inline-flex items-center gap-3 bg-ink px-7 py-4 font-display text-xl font-bold text-bone transition-colors hover:bg-bone hover:text-ink"
          >
            Request access
            <Chevron count={2} strokeWidth={6} class="chev-advance h-4 w-auto" />
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>
