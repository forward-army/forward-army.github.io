---
/**
 * Small brand/social glyphs on currentColor. Decorative by default
 * (aria-hidden) — the surrounding link carries the accessible name.
 */
interface Props {
  name: 'scholar' | 'linkedin';
  class?: string;
}
const { name, class: klass = '' } = Astro.props;
---
{name === 'scholar' && (
  <svg viewBox="0 0 24 24" fill="currentColor" class={klass} aria-hidden="true">
    <path d="M12 3 1 9l11 6 9-4.909V17h2V9L12 3z" />
    <path d="M5 13.18v3.685l7 3.82 7-3.82V13.18l-7 3.82-7-3.82z" />
  </svg>
)}
{name === 'linkedin' && (
  <svg viewBox="0 0 24 24" fill="currentColor" class={klass} aria-hidden="true">
    <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zm1.78 13.02H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z" />
  </svg>
)}
