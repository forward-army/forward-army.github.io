---
import '@fontsource-variable/bricolage-grotesque';
import '@fontsource-variable/public-sans';
import '@fontsource/ibm-plex-mono/500.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'forward.army — Forward-deployed agents. Under your command.',
  description = 'forward.army is the platform and operator that engineers purpose-built AI agents for your use cases and runs them inside your business — on your infrastructure, under your command. A forward-deployed operator, not another chatbot.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://forward.army').href;
const ogImage = new URL('/og.png', Astro.site ?? 'https://forward.army').href;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#141d18" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png" />
    <link rel="icon" href="/favicon-16x16.png" sizes="16x16" type="image/png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="forward.army" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="forward.army — Forward-deployed agents. Under your command." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Organization',
        name: 'forward.army',
        url: 'https://forward.army',
        description:
          'The platform for forward-deployed AI agents — controlled access, real proposals, shipped work.',
        slogan: 'Forward-deployed agents. Under your command.',
      })}
    />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:bg-ink focus:px-4 focus:py-2 focus:text-chalk"
    >
      Skip to content
    </a>
    <slot />

    <script>
      // Scroll reveal (used across all pages). Reduced-motion shows final state.
      const revealTargets = document.querySelectorAll('.reveal, [data-loop]');
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduceMotion || !('IntersectionObserver' in window)) {
        revealTargets.forEach((el) => el.classList.add('in-view'));
      } else {
        const io = new IntersectionObserver(
          (entries, obs) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
                obs.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.15, rootMargin: '0px 0px -8% 0px' },
        );
        revealTargets.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
